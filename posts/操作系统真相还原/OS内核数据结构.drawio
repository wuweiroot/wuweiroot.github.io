                <mxCell id="t-XHsLVWSgz46dE_N-Is-45" value="0xC8000" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" parent="t-XHsLVWSgz46dE_N-Is-1" vertex="1">
