                <mxCell id="foh_PmH5lSFeavgxrBmC-37" value="&lt;div style=&quot;color: rgb(204 , 204 , 204) ; background-color: rgb(31 , 31 , 31) ; font-family: &amp;#34;consolas&amp;#34; , &amp;#34;courier new&amp;#34; , monospace ; font-size: 14px ; line-height: 19px&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #569cd6&quot;&gt;struct&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0&quot;&gt;intr_stack&lt;/span&gt;&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;vec_no&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;edi&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;esi&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;ebp&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;esp_dummy&lt;/span&gt;;&lt;span style=&quot;color: #6a9955&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;ebx&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;edx&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;ecx&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;eax&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;gs&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;fs&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;es&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;ds&lt;/span&gt;;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #6a9955&quot;&gt;&amp;nbsp; &amp;nbsp; /* 以下由cpu从低特权级进入高特权级时压入 */&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;err_code&lt;/span&gt;;&lt;span style=&quot;color: #6a9955&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #569cd6&quot;&gt;void&lt;/span&gt; (&lt;span style=&quot;color: #d4d4d4&quot;&gt;*&lt;/span&gt;&lt;span style=&quot;color: #9cdcfe&quot;&gt;eip&lt;/span&gt;)(&lt;span style=&quot;color: #569cd6&quot;&gt;void&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;cs&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4ec9b0&quot;&gt;uint32_t&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe&quot;&gt;eflags&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #569cd6&quot;&gt;void&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4&quot;&gt;*&lt;/span&gt;&lt;span style=&quot