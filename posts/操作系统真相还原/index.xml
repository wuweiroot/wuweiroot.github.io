      <description>&lt;h1 id=&#34;pcb与线程切换&#34;&gt;pcb与线程切换&lt;a class=&#34;anchor&#34; href=&#34;#pcb%e4%b8%8e%e7%ba%bf%e7%a8%8b%e5%88%87%e6%8d%a2&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xA;&lt;p&gt;&#xD;&#xA;&lt;div class=&#34;post-img-view&#34;&gt;&#xD;&#xA;  &lt;a data-fancybox=&#34;gallery&#34; href=&#34;https://wuweiroot.github.io/images/OS%e5%86%85%e6%a0%b8%e6%95%b0%e6%8d%ae%e7%bb%93%e6%9e%84-pcb.svg&#34;&gt;&#xD;&#xA;    &lt;img src=&#34;https://wuweiroot.github.io/images/OS%e5%86%85%e6%a0%b8%e6%95%b0%e6%8d%ae%e7%bb%93%e6%9e%84-pcb.svg&#34; &#xD;&#xA;         alt=&#34;pcb与线程切换&#34; &#xD;&#xA;         /&gt;&#xD;&#xA;  &lt;/a&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/p&gt;&#xA;&lt;h1 id=&#34;内存分配&#34;&gt;内存分配&lt;a class=&#34;anchor&#34; href=&#34;#%e5%86%85%e5%ad%98%e5%88%86%e9%85%8d&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xA;&lt;p&gt;&#xD;&#xA;&lt;div class=&#34;post-img-view&#34;&gt;&#xD;&#xA;  &lt;a data-fancybox=&#34;gallery&#34; href=&#34;https://wuweiroot.github.io/images/OS%e5%86%85%e6%a0%b8%e6%95%b0%e6%8d%ae%e7%bb%93%e6%9e%84-%e5%86%85%e5%ad%98%e5%88%86%e9%85%8d.svg&#34;&gt;&#xD;&#xA;    &lt;img src=&#34;https://wuweiroot.github.io/images/OS%e5%86%85%e6%a0%b8%e6%95%b0%e6%8d%ae%e7%bb%93%e6%9e%84-%e5%86%85%e5%ad%98%e5%88%86%e9%85%8d.svg&#34; &#xD;&#xA;         alt=&#34;内存分配&#34; &#xD;&#xA;         /&gt;&#xD;&#xA;  &lt;/a&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/p&gt;&#xA;&lt;h1 id=&#34;文件系统&#34;&gt;文件系统&lt;a class=&#34;anchor&#34; href=&#34;#%e6%96%87%e4%bb%b6%e7%b3%bb%e7%bb%9f&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xA;&lt;p&gt;&#xD;&#xA;&lt;div class=&#34;post-img-view&#34;&gt;&#xD;&#xA;  &lt;a data-fancybox=&#34;gallery&#34; href=&#34;https://wuweiroot.github.io/images/OS%e5%86%85%e6%a0%b8%e6%95%b0%e6%8d%ae%e7%bb%93%e6%9e%84-%e6%96%87%e4%bb%b6%e7%b3%bb%e7%bb%9f.svg&#34;&gt;&#xD;&#xA;    &lt;img src=&#34;https://wuweiroot.github.io/images/OS%e5%86%85%e6%a0%b8%e6%95%b0%e6%8d%ae%e7%bb%93%e6%9e%84-%e6%96%87%e4%bb%b6%e7%b3%bb%e7%bb%9f.svg&#34; &#xD;&#xA;         alt=&#34;文件系统&#34; &#xD;&#xA;         /&gt;&#xD;&#xA;  &lt;/a&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/p&gt;&#xA;&lt;h1 id=&#34;磁盘分区&#34;&gt;磁盘分区&lt;a class=&#34;anchor&#34; href=&#34;#%e7%a3%81%e7%9b%98%e5%88%86%e5%8c%ba&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xA;&lt;p&gt;&#xD;&#xA;&lt;div class=&#34;post-img-view&#34;&gt;&#xD;&#xA;  &lt;a data-fancybox=&#34;gallery&#34; href=&#34;https://wuweiroot.github.io/images/OS%e5%86%85%e6%a0%b8%e6%95%b0%e6%8d%ae%e7%bb%93%e6%9e%84-%e7%a3%81%e7%9b%98%e5%88%86%e5%8c%ba.svg&#34;&gt;&#xD;&#xA;    &lt;img src=&#34;https://wuweiroot.github.io/images/OS%e5%86%85%e6%a0%b8%e6%95%b0%e6%8d%ae%e7%bb%93%e6%9e%84-%e7%a3%81%e7%9b%98%e5%88%86%e5%8c%ba.svg&#34; &#xD;&#xA;         alt=&#34;磁盘分区&#34; &#xD;&#xA;         /&gt;&#xD;&#xA;  &lt;/a&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/p&gt;&#xA;&lt;h1 id=&#34;页表&#34;&gt;页表&lt;a class=&#34;anchor&#34; href=&#34;#%e9%a1%b5%e8%a1%a8&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xA;&lt;p&gt;&#xD;&#xA;&lt;div class=&#34;post-img-view&#34;&gt;&#xD;&#xA;  &lt;a data-fancybox=&#34;gallery&#34; href=&#34;https://wuweiroot.github.io/images/OS%e5%86%85%e6%a0%b8%e6%95%b0%e6%8d%ae%e7%bb%93%e6%9e%84-%e9%a1%b5%e8%a1%a8.svg&#34;&gt;&#xD;&#xA;    &lt;img src=&#34;https://wuweiroot.github.io/images/OS%e5%86%85%e6%a0%b8%e6%95%b0%e6%8d%ae%e7%bb%93%e6%9e%84-%e9%a1%b5%e8%a1%a8.svg&#34; &#xD;&#xA;         alt=&#34;页表&#34; &#xD;&#xA;         /&gt;&#xD;&#xA;  &lt;/a&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;/p&gt;</description>
